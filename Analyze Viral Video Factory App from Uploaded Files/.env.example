# =================================================================================
# ENVIRONMENT VARIABLES FOR VIRAL VIDEO FACTORY
# =================================================================================
# Copy this file to .env.local for local development
# For Vercel deployment, set these as environment variables in your project settings

# REQUIRED: Core API Keys
# Get your Gemini API key from Google AI Studio: https://aistudio.google.com/
API_KEY=your_gemini_api_key_here

# REQUIRED: Supabase Configuration
# Get these from your Supabase project dashboard > Settings > API
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# OPTIONAL: Additional Service API Keys
# These enable specific features but the app will work without them

# Pexels API for stock video search
# Get from: https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key

# Stripe for payment processing
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Luma Dream Machine for AI video generation
# Get from: https://lumalabs.ai/
LUMA_API_KEY=your_luma_api_key

# Twitter/X OAuth for social media integration
# Get from: https://developer.twitter.com/
TWITTER_CLIENT_ID=your_twitter_client_id

